# Sentiment API - Copy to .env and fill in your keys
# Get Supabase: Project Settings > API in your Supabase dashboard
# Get AssemblyAI: https://www.assemblyai.com/app/account

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
ASSEMBLYAI_KEY=your-assemblyai-api-key
